{
  "version": 2,
  "builds": [
    {
      "src": "ProSync/backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "ProSync/frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "ProSync/backend/api/index.js"
    },
    {
      "src": "/health",
      "dest": "ProSync/backend/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "ProSync/frontend/$1"
    }
  ]
}
